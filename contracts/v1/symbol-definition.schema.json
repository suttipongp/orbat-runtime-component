{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbat.local/contracts/v1/symbol-definition.schema.json",
  "title": "ORBAT Symbol Definition",
  "type": "object",
  "required": [
    "contractVersion",
    "libraryId",
    "libraryRevision",
    "definitionId",
    "definitionRevision",
    "name",
    "domain",
    "role",
    "composition",
    "placeable",
    "classification",
    "scene"
  ],
  "properties": {
    "contractVersion": {
      "const": "1.0"
    },
    "libraryId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "libraryRevision": {
      "type": "integer",
      "minimum": 1
    },
    "definitionId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "definitionRevision": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "enum": [
        "land-unit",
        "equipment"
      ]
    },
    "role": {
      "enum": [
        "main-function",
        "modifier-1",
        "modifier-2",
        "echelon-indicator",
        "mobility-indicator",
        "amplifier",
        "equipment-function",
        "variant",
        "composite"
      ]
    },
    "composition": {
      "enum": [
        "composable",
        "composite"
      ]
    },
    "placeable": {
      "type": "boolean"
    },
    "classification": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string"
        },
        "function": {
          "type": "string"
        },
        "variant": {
          "type": "string"
        },
        "modifierType": {
          "type": "string"
        },
        "operatingState": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "properties": {
        "mainScaleWithoutModifiers": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "mainScaleWithOneModifier": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "mainScaleWithTwoModifiers": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "modifierWidthScale": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "modifierHeightScale": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "modifierCenterOffset": {
          "type": "number"
        },
        "mainSingleModifierOffset": {
          "type": "number"
        },
        "mainOffsetX": {
          "type": "number"
        },
        "mainOffsetY": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "scene": {
      "$ref": "https://orbat.local/contracts/v1/geometry.schema.json#/$defs/scene"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "role": {
            "enum": [
              "main-function",
              "composite"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "then": {
        "properties": {
          "placeable": {
            "const": true
          }
        }
      },
      "else": {
        "properties": {
          "placeable": {
            "const": false
          }
        }
      }
    }
  ]
}
