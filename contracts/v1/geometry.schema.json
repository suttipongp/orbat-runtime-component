{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbat.local/contracts/v1/geometry.schema.json",
  "title": "ORBAT Geometry",
  "description": "Platform-neutral normalized geometry and drawing primitives.",
  "$defs": {
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "viewBox": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "style": {
      "type": "object",
      "properties": {
        "stroke": { "type": ["string", "null"] },
        "strokeWidth": { "type": "number", "minimum": 0 },
        "fill": { "type": ["string", "null"] },
        "lineCap": { "enum": ["butt", "round", "square"] },
        "lineJoin": { "enum": ["miter", "round", "bevel"] },
        "dash": {
          "type": "array",
          "items": { "type": "number", "minimum": 0 }
        },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "primitiveBase": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "groupId": { "type": "string" },
        "rotationDegrees": { "type": "number" },
        "style": { "$ref": "#/$defs/style" }
      }
    },
    "line": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "end"],
          "properties": {
            "type": { "const": "line" },
            "start": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "rectangle": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "end"],
          "properties": {
            "type": { "const": "rectangle" },
            "start": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" },
            "cornerRadius": { "type": "number", "minimum": 0 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "ellipse": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "end"],
          "properties": {
            "type": { "enum": ["ellipse", "circle", "dot"] },
            "start": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "capsule": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "end"],
          "properties": {
            "type": { "const": "capsule" },
            "start": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "polyGeometry": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "points"],
          "properties": {
            "type": { "enum": ["polyline", "polygon", "path"] },
            "points": {
              "type": "array",
              "minItems": 2,
              "items": { "$ref": "#/$defs/point" }
            },
            "closed": { "type": "boolean" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "bezier": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "control1", "control2", "end"],
          "properties": {
            "type": { "const": "bezier" },
            "start": { "$ref": "#/$defs/point" },
            "control1": { "$ref": "#/$defs/point" },
            "control2": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "arc": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "end"],
          "properties": {
            "type": { "const": "arc" },
            "start": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" },
            "radius": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "sineWave": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "start", "end"],
          "properties": {
            "type": { "const": "sine-wave" },
            "start": { "$ref": "#/$defs/point" },
            "end": { "$ref": "#/$defs/point" },
            "cycles": { "type": "number", "exclusiveMinimum": 0 },
            "amplitude": { "type": "number", "minimum": 0 }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "text": {
      "allOf": [
        { "$ref": "#/$defs/primitiveBase" },
        {
          "type": "object",
          "required": ["type", "position", "text"],
          "properties": {
            "type": { "const": "text" },
            "position": { "$ref": "#/$defs/point" },
            "text": { "type": "string" },
            "fontFamily": { "type": "string" },
            "fontSize": { "type": "number", "exclusiveMinimum": 0 },
            "fontWeight": { "enum": ["normal", "bold"] },
            "textAnchor": { "enum": ["start", "middle", "end"] }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "primitive": {
      "oneOf": [
        { "$ref": "#/$defs/line" },
        { "$ref": "#/$defs/rectangle" },
        { "$ref": "#/$defs/ellipse" },
        { "$ref": "#/$defs/capsule" },
        { "$ref": "#/$defs/polyGeometry" },
        { "$ref": "#/$defs/bezier" },
        { "$ref": "#/$defs/arc" },
        { "$ref": "#/$defs/sineWave" },
        { "$ref": "#/$defs/text" }
      ]
    },
    "scene": {
      "type": "object",
      "required": ["coordinateSpace", "viewBox", "primitives"],
      "properties": {
        "coordinateSpace": { "const": "normalized-cartesian" },
        "viewBox": { "$ref": "#/$defs/viewBox" },
        "primitives": {
          "type": "array",
          "items": { "$ref": "#/$defs/primitive" }
        }
      },
      "additionalProperties": false
    },
    "geoPoint": {
      "type": "array",
      "prefixItems": [
        { "type": "number", "minimum": -180, "maximum": 180 },
        { "type": "number", "minimum": -90, "maximum": 90 },
        { "type": "number" }
      ],
      "minItems": 2,
      "maxItems": 3
    }
  }
}
