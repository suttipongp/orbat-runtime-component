{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbat.local/contracts/v1/extension-manifest.schema.json",
  "title": "C4ISR ORBAT Extension Manifest",
  "type": "object",
  "required": [
    "contractVersion",
    "id",
    "name",
    "version",
    "publisher",
    "description",
    "enabled",
    "requiredPermissions",
    "contributions"
  ],
  "properties": {
    "contractVersion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "publisher": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "enabled": { "type": "boolean" },
    "requiredPermissions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "protocol": {
      "type": "object",
      "required": ["type", "version"],
      "properties": {
        "type": { "enum": ["static-assets", "http", "json-rpc", "websocket", "wasm"] },
        "version": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string" },
        "entryPoint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "contributions": {
      "type": "object",
      "properties": {
        "mapLayers": {
          "type": "array",
          "items": { "$ref": "#/$defs/mapLayer" }
        },
        "importConnectors": {
          "type": "array",
          "items": { "$ref": "#/$defs/importConnector" }
        },
        "overlayDrawTools": {
          "type": "array",
          "items": { "$ref": "#/$defs/overlayDrawTool" }
        },
        "symbolRenderers": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbolRenderer" }
        },
        "symbolTemplates": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbolTemplate" }
        },
        "tacticalGraphicTemplates": {
          "type": "array",
          "items": { "$ref": "#/$defs/tacticalGraphicTemplate" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "permissioned": {
      "type": "object",
      "required": ["id", "title", "requiredPermission"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "requiredPermission": { "type": "string", "minLength": 1 }
      }
    },
    "mapLayer": {
      "allOf": [
        { "$ref": "#/$defs/permissioned" },
        {
          "type": "object",
          "required": ["layerType", "domain", "provider"],
          "properties": {
            "layerType": { "type": "string" },
            "domain": { "type": "string" },
            "provider": { "type": "string" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "importConnector": {
      "allOf": [
        { "$ref": "#/$defs/permissioned" },
        {
          "type": "object",
          "required": ["accepts", "target"],
          "properties": {
            "accepts": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "target": { "type": "string" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "overlayDrawTool": {
      "allOf": [
        { "$ref": "#/$defs/permissioned" },
        {
          "type": "object",
          "required": ["geometryType", "staffSectionCode", "handler", "description"],
          "properties": {
            "geometryType": { "enum": ["Point", "LineString", "Polygon"] },
            "staffSectionCode": { "type": "string" },
            "handler": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "symbolRenderer": {
      "allOf": [
        { "$ref": "#/$defs/permissioned" },
        {
          "type": "object",
          "required": [
            "standard",
            "version",
            "renderer",
            "supportedAffiliations",
            "supportedEchelons"
          ],
          "properties": {
            "standard": { "type": "string" },
            "version": { "type": "string" },
            "renderer": { "type": "string" },
            "supportedAffiliations": {
              "type": "array",
              "items": { "type": "string" }
            },
            "supportedEchelons": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "symbolTemplate": {
      "allOf": [
        { "$ref": "#/$defs/permissioned" },
        {
          "type": "object",
          "required": [
            "standard",
            "symbolSet",
            "unitType",
            "defaultAffiliation",
            "description",
            "definition"
          ],
          "properties": {
            "standard": { "type": "string" },
            "symbolSet": { "type": "string" },
            "unitType": { "type": "string" },
            "defaultAffiliation": { "type": "string" },
            "description": { "type": "string" },
            "definition": {
              "$ref": "https://orbat.local/contracts/v1/common.schema.json#/$defs/definitionReference"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "tacticalGraphicTemplate": {
      "allOf": [
        { "$ref": "#/$defs/permissioned" },
        {
          "type": "object",
          "required": ["standard", "geometryType", "category", "description", "definition"],
          "properties": {
            "standard": { "type": "string" },
            "geometryType": { "enum": ["Point", "LineString", "Polygon"] },
            "category": { "type": "string" },
            "description": { "type": "string" },
            "definition": {
              "$ref": "https://orbat.local/contracts/v1/common.schema.json#/$defs/definitionReference"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  }
}
