{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbat.local/contracts/v1/geojson.schema.json",
  "title": "ORBAT GeoJSON Profile",
  "description": "WGS84 GeoJSON geometry used by the C4ISR Workbench host profile.",
  "$defs": {
    "position": {
      "type": "array",
      "prefixItems": [
        { "type": "number", "minimum": -180, "maximum": 180 },
        { "type": "number", "minimum": -90, "maximum": 90 },
        { "type": "number" }
      ],
      "minItems": 2,
      "maxItems": 3
    },
    "point": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": { "$ref": "#/$defs/position" }
      },
      "additionalProperties": false
    },
    "lineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "LineString" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/position" }
        }
      },
      "additionalProperties": false
    },
    "polygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 4,
            "items": { "$ref": "#/$defs/position" }
          }
        }
      },
      "additionalProperties": false
    },
    "geometry": {
      "oneOf": [
        { "$ref": "#/$defs/point" },
        { "$ref": "#/$defs/lineString" },
        { "$ref": "#/$defs/polygon" }
      ]
    }
  }
}
